# Systems Admin Agent Configuration
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key for the AI brain
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Password to protect the web UI (leave empty for no auth)
WEB_PASSWORD=

# Optional: Flask secret key (auto-generated if not set)
SECRET_KEY=

# Optional: AI model to use (default: claude-sonnet-4-20250514)
# Use claude-sonnet-4-20250514 for cost efficiency, claude-opus-4-20250514 for complex tasks
AI_MODEL=claude-sonnet-4-20250514
